# Ambiente virtual
venv/
models/
reports/

# Arquivos compilados
__pycache__/
*.pyc
*.pyo

# Logs
*.log

# Configurações locais
.env
# Crie ou edite o .gitignore
echo "*.pkl" >> .gitignore
echo "models/" >> .gitignore
echo "reports/" >> .gitignore

# Remova o arquivo do controle do Git
git rm --cached modelo.pkl
git rm --cached -r models/ 2>/dev/null || true
git rm --cached -r reports/ 2>/dev/null || true

# Crie/edite .gitignore
echo ".vscode/" >> .gitignore
echo "*.pyc" >> .gitignore
echo "__pycache__/" >> .gitignore
echo "venv/" >> .gitignore
echo ".env" >> .gitignore

